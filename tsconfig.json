// tsconfig.json
{
  "compilerOptions": {
    "target": "ESNext",
    // Ustawiamy nowoczesny system modułów i ich rozwiązywania
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
